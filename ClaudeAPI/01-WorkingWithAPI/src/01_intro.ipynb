   "source": [
    "# Intro\n",
    "\n",
    "## New env\n",
    "\n",
    "```\n",
    "uv venv\n",
    "```\n",
    "\n",
    "## Activate env\n",
    "\n",
    "```\n",
    "./.venv/Scripts/activate\n",
    "```\n",
    "\n",
    "## Install packages\n",
    "\n",
    "```\n",
    " uv pip install anthropic python-dotenv\n",
    "```\n",
    "or\n",
    "\n",
    "```\n",
    "uv pip install -r requirements.txt\n",
    "```\n",
    "\n",
    "## Genertate Requirements file\n",
    "\n",
    "```\n",
    "uv pip freeze > requirements.txt\n",
    "```"
   ]
  }
